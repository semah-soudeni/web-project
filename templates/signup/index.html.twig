{% extends 'base.html.twig' %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('assets/styles/signup.css') }}?v=1">
{% endblock %}
{% block body %}
    <div class="container">
        <div class="signup">
            <div class="form-box">
                <h1>Create Account</h1>
                <p>Join INSAT students community now</p>

                <div class="success-message" id="successMessage">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                    </svg>
                    Account created successfully! Redirecting...
                </div>

                {{ form_start(Sform, { attr: { class: 'signup-form', id: 'signupForm' } }) }}
                    <div class="row">
                        <div class="input-group">
                            {{ form_label(Sform.firstName) }}
                            {{ form_widget(Sform.firstName) }}
                            {{ form_errors(Sform.firstName) }}
                        </div>
                        <div class="input-group">
                            {{ form_label(Sform.lastName) }}
                            {{ form_widget(Sform.lastName) }}
                            {{ form_errors(Sform.lastName) }}
                        </div>
                    </div>

                    <div class="input-group">
                        {{ form_label(Sform.email) }}
                        {{ form_widget(Sform.email) }}
                        {{ form_errors(Sform.email) }}
                    </div>

                    <div class="input-group">
                        {{ form_label(Sform.phone) }}
                        {{ form_widget(Sform.phone) }}
                        {{ form_errors(Sform.phone) }}
                    </div>

                    <div class="input-group">
                        {{ form_label(Sform.password) }}
                        {{ form_widget(Sform.password) }}
                        {{ form_errors(Sform.password) }}
                        <div class="password-strength" id="passwordStrength">
                            <div class="strength-bars">
                                <div class="strength-bar"></div>
                                <div class="strength-bar"></div>
                                <div class="strength-bar"></div>
                                <div class="strength-bar"></div>
                            </div>
                            <span class="strength-text">Password strength: <span id="strengthText">Weak</span></span>
                        </div>
                    </div>
                    {{ form_widget(Sform.submit, { attr: { id: 'submitBtn' } }) }}
                {{ form_end(Sform) }}

                <div class="divider">or sign up with</div>
                <div class="oauth">
                    <button type="button" class="oauth-btn" onclick="handleOAuth('google')">
                        <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                          <path fill="#4285F4"
                            d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                          <path fill="#34A853"
                            d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                          <path fill="#FBBC05"
                            d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                          <path fill="#EA4335"
                            d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                        </svg>
                        Continue with Google
                    </button>
                    <button type="button" class="oauth-btn github-btn" onclick="handleOAuth('github')">
                        <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true">
                          <path d="M12 .297c-6.63 0-12 5.373-12 12
                          0 5.303 3.438 9.8 8.205 11.385
                          .6.113.82-.258.82-.577
                          0-.285-.01-1.04-.015-2.04
                          -3.338.724-4.042-1.61-4.042-1.61
                          -.546-1.387-1.333-1.757-1.333-1.757
                          -1.089-.745.084-.73.084-.73
                          1.205.084 1.838 1.236 1.838 1.236
                          1.07 1.835 2.809 1.305 3.495.998
                          .108-.776.418-1.305.762-1.605
                          -2.665-.3-5.466-1.332-5.466-5.93
                          0-1.31.465-2.38 1.235-3.22
                          -.135-.303-.54-1.523.105-3.176
                          0 0 1.005-.322 3.3 1.23
                          .96-.267 1.98-.399 3-.405
                          1.02.006 2.04.138 3 .405
                          2.28-1.552 3.285-1.23 3.285-1.23
                          .645 1.653.24 2.873.12 3.176
                          .765.84 1.23 1.91 1.23 3.22
                          0 4.61-2.805 5.625-5.475 5.92
                          .435.375.81 1.11.81 2.24
                          0 1.62-.015 2.92-.015 3.32
                          0 .315.21.69.825.57
                          C20.565 22.092 24 17.592 24 12.297
                          24 5.67 18.63.297 12 .297z"/>
                        </svg>
                        Continue with GitHub
                    </button>
                </div>


                <div class="login-link">
                    Already have an account? <a href="{{ path('signin') }}">Sign in</a>
                </div>
            </div>
        </div>

        <!-- IMAGE SECTION -->
        <div class="image-side">
            <div class="image-content">
                <h2>Welcome to Your Academic Journey</h2>
                <p>
                    Connect with fellow students, discover campus events, join clubs, 
                    and unlock exclusive opportunities — all in one powerful platform.
                </p>
                <div class="features">
                    <div class="feature-item">
                        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        Verified Students
                    </div>
                    <div class="feature-item">
                        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                        </svg>
                        Secure Platform
                    </div>
                    <div class="feature-item">
                        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
                        </svg>
                        Instant Access
                    </div>
                </div>
            </div>
        </div>
    </div>


{% endblock %}
