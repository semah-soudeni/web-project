{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .reg-page {
            min-height: calc(100vh - 64px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
            background: var(--color-background-tertiary);
        }

        .reg-card {
            width: min(680px, 100%);
            background: var(--color-background-primary);
            border: 0.5px solid var(--color-border-tertiary);
            border-radius: var(--border-radius-lg);
            padding: 2rem 2.5rem;
        }

        .reg-card h1 {
            font-size: 1.5rem;
            font-weight: 500;
            margin: 0 0 0.375rem;
            color: var(--color-text-primary);
        }

        .reg-subtitle {
            font-size: 0.95rem;
            color: var(--color-text-secondary);
            margin: 0 0 1.75rem;
        }

        .reg-form {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        .reg-field {
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
        }

        .reg-field label {
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--color-text-primary);
        }

        .reg-field input,
        .reg-field textarea {
            width: 100%;
            border: 0.5px solid var(--color-border-secondary);
            border-radius: var(--border-radius-md);
            padding: 0.6rem 0.85rem;
            font: inherit;
            font-size: 0.95rem;
            color: var(--color-text-primary);
            background: var(--color-background-primary);
            outline: none;
            transition: border-color 0.15s, box-shadow 0.15s;
            box-sizing: border-box;
        }

        .reg-field input:focus,
        .reg-field textarea:focus {
            border-color: var(--color-border-primary);
            box-shadow: 0 0 0 3px rgba(15, 118, 110, 0.12);
        }

        .reg-field textarea {
            resize: vertical;
            min-height: 100px;
        }

        .reg-hint {
            font-size: 0.82rem;
            color: var(--color-text-tertiary);
            margin: 0;
        }

        .reg-actions {
            display: flex;
            gap: 0.75rem;
            margin-top: 0.5rem;
            flex-wrap: wrap;
        }

        .reg-btn-primary {
            background: #0f766e;
            color: #ffffff !important;
            border: none;
            border-radius: var(--border-radius-md);
            padding: 0.6rem 1.4rem;
            font-size: 0.95rem;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: background 0.15s, transform 0.15s;
            line-height: 1.5;
        }

        .reg-btn-primary:hover {
            background: #0a5a54;
            transform: translateY(-1px);
        }

        .reg-btn-ghost {
            background: var(--color-background-secondary);
            color: var(--color-text-primary) !important;
            border: 0.5px solid var(--color-border-secondary);
            border-radius: var(--border-radius-md);
            padding: 0.6rem 1.4rem;
            font-size: 0.95rem;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: background 0.15s;
            line-height: 1.5;
        }

        .reg-btn-ghost:hover {
            background: var(--color-background-tertiary);
        }

        @media (max-width: 600px) {
            .reg-card { padding: 1.5rem 1.25rem; }
            .reg-actions { flex-direction: column; }
            .reg-btn-primary,
            .reg-btn-ghost { width: 100%; justify-content: center; }
        }
    </style>
{% endblock %}

{% block body %}
<div class="reg-page">
    <div class="reg-card">

        <h1>Register for {{ event.title }}</h1>
        <p class="reg-subtitle">Fill in the details below to complete your registration.</p>

        <form class="reg-form"
              action="{{ path('events_registration', {'event_id': event.id}) }}"
              method="post">

            <div class="reg-field">
                <label for="team_name">Team Name <span style="color: var(--color-text-tertiary); font-weight: 400;">(optional)</span></label>
                <input type="text" id="team_name" name="team_name"
                       maxlength="300" placeholder="e.g. The Bug Hunters">
            </div>

            <div class="reg-field">
                <label for="team_nb_memebers">Number of Team Members <span style="color: var(--color-text-tertiary); font-weight: 400;">(optional)</span></label>
                <input type="number" id="team_nb_memebers" name="team_nb_memebers"
                       min="1" max="20" placeholder="e.g. 3">
            </div>

            <div class="reg-field">
                <label for="links">Links <span style="color: var(--color-text-tertiary); font-weight: 400;">(optional)</span></label>
                <textarea id="links" name="links" maxlength="1000"
                          placeholder="Portfolio, GitHub, LinkedIn…"></textarea>
                <p class="reg-hint">Paste one or more links, one per line.</p>
            </div>

            <div class="reg-actions">
                <button type="submit" class="reg-btn-primary">
                    <i class="ti ti-check" aria-hidden="true"></i>
                    Register
                </button>
                <a class="reg-btn-ghost" href="{{ path('events') }}">
                    <i class="ti ti-arrow-left" aria-hidden="true"></i>
                    Back to Events
                </a>
            </div>

        </form>
    </div>
</div>
{% endblock %}