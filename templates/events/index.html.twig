{% extends 'base.html.twig' %}

{% block stylesheets %}
<link rel="stylesheet" href="/assets/styles/events.css?v=1">
{% endblock %}
    
{% block javascripts %}
<script src="/assets/js/events.js"></script>
{% endblock %}

{% block body %}
<section class="header-section">
    <div class="header-container">
        <h1 class="header-title">Upcoming Events</h1>
        <p class="header-subtitle">Discover and participate in exciting events from all our clubs</p>
    </div>
</section>

<section class="filter-section">
    <div class="container">
        <div class="filters">
            <button class="filter-btn {{ selectedClub == 'all' ? 'active' : '' }}" type="button" data-club="all">All Clubs</button>
            <button class="filter-btn {{ selectedClub == 'aero' ? 'active' : '' }}" type="button" data-club="aero">Aerobotix</button>
            <button class="filter-btn {{ selectedClub == 'secu' ? 'active' : '' }}" type="button" data-club="secu">Securinets</button>
            <button class="filter-btn {{ selectedClub == 'ieee' ? 'active' : '' }}" type="button" data-club="ieee">IEEE</button>
            <button class="filter-btn {{ selectedClub == 'acm' ? 'active' : '' }}" type="button" data-club="acm">ACM</button>
            <button class="filter-btn {{ selectedClub == 'android' ? 'active' : '' }}" type="button" data-club="android">Android Club</button>
            <button class="filter-btn {{ selectedClub == 'cim' ? 'active' : '' }}" type="button" data-club="cim">CIM</button>
        </div>
    </div>
</section>
<section class="event-section">
    <div class="container">
        <div id="events-container">
            {% if queryError %}
                <div class="empty-state">
                    <h3>Could not load events</h3>
                    <p>Please make sure your database server is running.</p>
                </div>
            {% elseif groupedEvents is empty %}
                <div class="empty-state">
                    <h3>No events found</h3>
                    <p>There are no upcoming events for this club at the moment.</p>
                </div>
            {% else %}
              {% for monthYear, group in groupedEvents %}
                    <div class="month-group">
                        <h2 class="month-title">{{ monthYear }}</h2>

                        {% for event in group['items'] %}
                            {% set slugs = event.getClubs()|map(c => c.getSlug()) %}

                            {% set eventDate = event.getEventDate()%}
                            {% set day = eventDate.format('d') %}
                            {% set month = eventDate.format('F') %}
                            <div class="event-card" data-club="{{ slugs|map(s => s|trim)|join(',') }}">
                                <div class="date-badge">
                                    <div class="day-badge">{{ day }}</div>
                                    <div class="month-badge">{{ month }}</div>
                                </div>

                                <div class="event-content">
                                    <div class="event-header">
                                        <div class="club-tags" style="display:flex; gap:6px; flex-wrap:wrap;">
                                            {% for s in slugs %}
                                                {% set s = s|trim %}
                                                {% set color = clubColors[s] %}
                                                {% set label = clubNames[s] %}
                                                <div class="club-tag {{ s }}"
                                                    style="background-color: {{ color }}">
                                                    {{ label }}
                                                </div>
                                            {% endfor %}
                                        </div>
                                        <div class="event-hour">🕐 {{ event.getEventTime().format('h-m') }}</div>
                                    </div>

                                    <h3 class="event-title">{{ event.getTitle() }}</h3>
                                    <p class="event-desc">{{ event.getDescription() }}</p>

                                    <div class="event-footer">
                                        <div class="event-location">
                                            <span class="location-icon">📍</span>
                                            <span>{{ event.getLocation() }}</span>
                                        </div>

                                        <div class="event-location">
                                            <span>👥</span>
                                            <span>{{ event.getAttendees() }} attendees</span>
                                        </div>

                                        {% if is_registered[event.getId()] %}
                                            <a class="register-btn" aria-disabled="true" style="opacity:0.6; pointer-events:none;">Registered ✓</a>
                                        {% else %}
                                            <a class="register-btn" href="{{ path('events_registration', {'event_id': event.getId()}) }}">Register</a>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</section>
{% endblock %}
