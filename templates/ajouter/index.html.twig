{% extends 'base.html.twig' %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('assets/styles/style.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/styles/ajouter.css') }}">

{% endblock %}

{% block navigation %} 
{% endblock %}

{% block javascripts %}
{% endblock %}

{% block body %}
<section class="form-wrapper">
<h1>Add Member to Club</h1>
<p class="subtitle">Fill in the form below to register a new club member.</p>

{{ form_start(Aform, { action: path('add_membership'), method: 'POST', attr: { class: 'signup-form' } }) }}
    <div class="grid">
        <div class="field">
            {{ form_label(Aform.club) }}
            {{ form_widget(Aform.club) }}
            {{ form_errors(Aform.club) }}
        </div>

        <div class="field">
            {{ form_label(Aform.role) }}
            {{ form_widget(Aform.role) }}
            {{ form_errors(Aform.role) }}
        </div>

        <div class="field">
            {{ form_label(Aform.firstName) }}
            {{ form_widget(Aform.firstName) }}
            {{ form_errors(Aform.firstName) }}
        </div>

        <div class="field">
            {{ form_label(Aform.lastName) }}
            {{ form_widget(Aform.lastName) }}
            {{ form_errors(Aform.lastName) }}
        </div>

        <div class="field">
            {{ form_label(Aform.email) }}
            {{ form_widget(Aform.email) }}
            {{ form_errors(Aform.email) }}
        </div>

        <div class="field">
            {{ form_label(Aform.phone) }}
            {{ form_widget(Aform.phone) }}
            {{ form_errors(Aform.phone) }}
        </div>

        <div class="field">
            {{ form_label(Aform.studentId) }}
            {{ form_widget(Aform.studentId) }}
            {{ form_errors(Aform.studentId) }}
        </div>

        <div class="field">
            {{ form_label(Aform.year) }}
            {{ form_widget(Aform.year) }}
            {{ form_errors(Aform.year) }}
        </div>

        <div class="field full actions">
            {{ form_widget(Aform.submit, { attr: { class: 'btn-primary' } }) }}
            <button type="reset" class="btn-secondary">Reset</button>
        </div>
    </div>
{{ form_end(Aform) }}
</section>
{% endblock %}
