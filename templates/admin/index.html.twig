{% extends 'base.html.twig' %}

{% block title %}Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('assets/styles/admin.css') }}?v=1">
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/js/admin.js') }}" defer></script>
{% endblock %}

{% block body %}
<main class="dashboard">

    <section class="hero">
        <div class="grid-overlay"></div>
        <div class="hero-content">
            <div class="hero-badge">Admin Dashboard</div>
            <h1 class="hero-title">
                Bring your community<br>
                <span>together with events</span>
            </h1>
            <p class="hero-subtitle">
                Create, manage, and promote events that your club members will love.
            </p>
            <div class="hero-actions">
                <a class="btn-primary" href="{{ path('add_events') }}">Create an event</a>
                <a class="btn-secondary" href="{{ path('events') }}">View all events</a>
            </div>
        </div>
    </section>

    <section class="email-broadcast">
        {# ... email broadcast section stays exactly the same ... #}
    </section>

    <section class="events-section">
        <div class="events-header">
            <div>
                <h2 class="events-title">Manage Events</h2>
                <p class="events-subtitle">View, edit, and delete your club events</p>
            </div>
        </div>

        <div class="events-grid">
            {% for event in events %}
                <div class="event-card">
                    <div class="event-card-header">
                        <span class="event-type-badge event-type-{{ event.eventType|lower }}">
                            {{ event.eventType }}
                        </span>
                        <div class="event-actions">
                            <button class="event-action-btn event-edit-btn"
                                    onclick="editEvent('{{ event.title|escape('js') }}')"
                                    title="Edit event">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                </svg>
                            </button>
                            <button class="event-action-btn event-delete-btn"
                                    onclick="confirmDeleteEvent('{{ event.title|escape('js') }}')"
                                    title="Delete event">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="3 6 5 6 21 6"></polyline>
                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <h3 class="event-title">{{ event.title }}</h3>
                    <p class="event-description">{{ event.description }}</p>

                    <div class="event-meta-grid">
                        <div class="event-meta-item">
                            <svg class="event-meta-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                <line x1="3" y1="10" x2="21" y2="10"></line>
                            </svg>
                            <span>{{ event.eventDate ? event.eventDate|date('M d, Y') : 'TBA' }}</span>
                        </div>

                        <div class="event-meta-item">
                            <svg class="event-meta-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                            <span>{{ event.eventTime ? event.eventTime|date('g:i A') : 'TBA' }}</span>
                        </div>

                        {% if event.duration %}
                            <div class="event-meta-item">
                                <span>{{ event.duration }} min</span>
                            </div>
                        {% endif %}

                        {% if event.location %}
                            <div class="event-meta-item">
                                <svg class="event-meta-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                    <circle cx="12" cy="10" r="3"></circle>
                                </svg>
                                <span>{{ event.location }}</span>
                            </div>
                        {% endif %}

                        {% if event.maxAttendees %}
                            <div class="event-meta-item">
                                <span>Max {{ event.maxAttendees }} attendees</span>
                            </div>
                        {% endif %}
                    </div>

                    {% if event.prizePool %}
                        <div class="event-prize">
                            <span>🏆 {{ event.prizePool }}</span>
                        </div>
                    {% endif %}

                    {% if event.clubs is not empty %}
                        <div class="event-clubs">
                            <span class="event-clubs-label">Participating clubs:</span>
                            <div class="event-clubs-list">
                                {% for club in event.clubs %}
                                    <span class="event-club-tag">{{ club.name }}</span>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}

                    {% if event.staff is not empty %}
                        <div class="event-staff-section">
                            <span class="event-staff-header">Staff members</span>
                            <div class="event-staff-grid">
                                {% for staffMember in event.staff %}
                                    <div class="staff-card">
                                        <div class="staff-info">
                                            <p class="staff-name">{{ staffMember.user.firstName }} {{ staffMember.user.lastName }}</p>
                                            <p class="staff-role">{{ staffMember.role }}</p>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}

                </div>

            {% else %}
                <div class="events-empty">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                    <h3>No events yet</h3>
                    <p>Create your first event to get started</p>
                </div>
            {% endfor %}
        </div>
    </section>

    {# Delete modal — unchanged #}
    <div id="deleteModal" class="delete-modal-overlay">
        <div class="delete-modal">
            <h3 class="delete-modal-title">Delete Event</h3>
            <p class="delete-modal-text">Are you sure you want to delete "<span id="deleteEventName"></span>"? This action cannot be undone.</p>
            <div class="delete-modal-actions">
                <button class="delete-modal-cancel" onclick="closeDeleteModal()">Cancel</button>
                <button class="delete-modal-confirm" onclick="deleteEvent()">Delete Event</button>
            </div>
        </div>
    </div>

    {# Broadcast modal — unchanged #}
    <div id="broadcastModal" class="bm-overlay">
        {# ... same as before ... #}
    </div>

    {# Toast container — unchanged #}
    <div id="toastContainer" class="toast-container">
        {# ... same as before ... #}
    </div>

</main>
{% endblock %}