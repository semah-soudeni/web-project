<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ pageTitle }}</title>
    <link rel="stylesheet" href="/assets/styles/style.css?v=1">
    {% block stylesheets %}
    {% endblock %}
</head>

<body>
    {% block navigation %}
    <nav class="navigation">
        <div class="nav-container">
            <div class="nav-menu">
                <a href="{{ path('home') }}" class="nav-link ">Clubs</a>
                <a href="{{ path('events') }}" class="nav-link ">Events</a>
                <a href="{{ path('map') }}" class="nav-link ">Map</a>
                {% if is_granted('admin') %}
                    <a href="{{ path('admin') }}" class="nav-link {{ activePage == 'admin' ? 'active' : '' }}">Admin Dashboard</a>
                {% endif %}
            </div>
            <div class="nav-login">
                {% if app.user %}
                    <form action="<?= BASE_URL ?>backend/logout.php" method="POST" style="display:flex; align-items:center; gap:20px;">
                        <span style="font-weight:600;">Hi, {{ app.user.firstName }}</span>
                        <button type="submit" class="signin-btn">Sign Out</button>
                    </form>
                {% else %}
                    <a href="{{ path('signin') }}" class="signin-btn">Sign In</a>
                    <a href="{{ path('signup') }}" class="signup-btn">Sign Up</a>
                {% endif %}
            </div>
        </div>
    </nav>
    {% endblock %}
    {% block body %}{% endblock %}
    {% block javascripts %}
    {% endblock %}
</body>
</html>
